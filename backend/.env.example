PORT=4000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
DATABASE_PATH=./agents.db

# Optional LLM parsing. If absent, a local chrono-node parser is used.
# LLM_PROVIDER can be: abacus | openai | local
LLM_PROVIDER=local

ABACUSAI_API_KEY=
ABACUS_BASE_URL=https://routellm.abacus.ai/v1
ABACUS_MODEL=route-llm

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# local | voice | telegram | discord
NOTIFICATION_PROVIDER=voice
VOICE_NAME=Microsoft Zira Desktop
VOICE_RATE=-1
VOICE_VOLUME=100

# Experimental wake-word mode. Keep disabled if you use the browser mic,
# because always-on listening can compete for the microphone on Windows.
WAKE_WORD_ENABLED=false
WAKE_WORD_PHRASE=hey echo

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
