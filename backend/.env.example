PORT=4000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://echo-96caa.web.app,https://echo-96caa.firebaseapp.com
DATABASE_PATH=./agents.db

# Use hosted Postgres in production instead of agents.db.
# Free options include Neon, Supabase, or Railway Postgres.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# DATABASE_SSL=true

# Or use Firebase Firestore in production.
# Set DATABASE_PROVIDER=firebase and provide either a service account JSON or
# Google application-default credentials on the host.
# DATABASE_PROVIDER=firebase
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

ADMIN_EMAIL=your-email@example.com
AUTH_SECRET=replace-with-a-long-random-secret
ALLOW_PASSWORD_SIGNUP=false

# Optional LLM parsing. If absent, a local chrono-node parser is used.
# LLM_PROVIDER can be: abacus | openai | local
LLM_PROVIDER=local

ABACUSAI_API_KEY=
ABACUS_BASE_URL=https://routellm.abacus.ai/v1
ABACUS_MODEL=route-llm

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview
GEMINI_LIVE_VOICE=Kore

# local | voice | telegram | discord
NOTIFICATION_PROVIDER=push
VOICE_NAME=Microsoft Zira Desktop
VOICE_RATE=-1
VOICE_VOLUME=100

# Text-to-speech provider for /api/speech/speak.
# edge = current default fallback, google = Google Cloud Text-to-Speech
TTS_PROVIDER=edge
TTS_VOICE=en-US-JennyNeural
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_VOICE=en-US-Neural2-F
GOOGLE_TTS_SPEAKING_RATE=1.12
GOOGLE_TTS_PITCH=0
GOOGLE_TTS_VOLUME_GAIN_DB=0
# Optional overrides if you want separate Google credentials for TTS.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
# GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json

# Experimental wake-word mode. Turn this on for Alexa-style system mic listening.
# If enabled, say "hey Echo", wait for "Hello, I am listening", then ask.
WAKE_WORD_ENABLED=false
ENABLE_LOCAL_SCHEDULER=false
WAKE_WORD_PHRASE=hey echo
WAKE_WORD_MIN_CONFIDENCE=0.7

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Browser/mobile push notifications. Generate these once with:
# node -e "import('web-push').then(({default:w})=>console.log(w.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com
APP_URL=https://echo-96caa.web.app/
